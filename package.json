{
  "name": "campus-lost-and-found",
  "private": true,
  "version": "0.1.0",
  "description": "Campus Lost & Found (static frontend + local backend)",
  "scripts": {
    "dev": "concurrently -k \"npm:dev:api\" \"npm:dev:web\"",
    "dev:api": "node backend/server.js",
    "dev:web": "http-server -p 5173 -c-1 .",
    "db:reset": "node backend/scripts/reset-db.js"
  },
  "dependencies": {
    "bcryptjs": "^3.0.2",
    "better-sqlite3": "^12.2.0",
    "cors": "^2.8.5",
    "express": "^4.21.2",
    "pg": "^8.16.3",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "concurrently": "^9.2.1",
    "http-server": "^14.1.1"
  }
}
